{
    "name": "interactive-scenario-modeller",
    "version": "0.1.0",
    "type": "module",
    "description": "A small, extensible scenario modeller library for decarbonisation scenarios",
    "main": "dist/index.cjs.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs.js",
            "types": "./dist/index.d.ts"
        },
        "./plugins": {
            "import": "./dist/plugins/installers.js",
            "require": "./dist/plugins/installers.cjs.js",
            "types": "./dist/plugins/installers.d.ts"
        },
        "./plugins/grid": {
            "import": "./dist/plugins/grid/index.js",
            "require": "./dist/plugins/grid/index.cjs.js",
            "types": "./dist/plugins/grid/index.d.ts"
        },
        "./plugins/financial": {
            "import": "./dist/plugins/financial/index.js",
            "require": "./dist/plugins/financial/index.cjs.js",
            "types": "./dist/plugins/financial/index.d.ts"
        },
        "./plugins/geographic": {
            "import": "./dist/plugins/geographic/index.js",
            "require": "./dist/plugins/geographic/index.cjs.js",
            "types": "./dist/plugins/geographic/index.d.ts"
        },
        "./plugins/optimization": {
            "import": "./dist/plugins/optimization/index.js",
            "require": "./dist/plugins/optimization/index.cjs.js",
            "types": "./dist/plugins/optimization/index.d.ts"
        },
        "./plugins/transport": {
            "import": "./dist/plugins/transport/index.js",
            "require": "./dist/plugins/transport/index.cjs.js",
            "types": "./dist/plugins/transport/index.d.ts"
        },
        "./adapters/uk": {
            "import": "./dist/adapters/uk/index.js",
            "require": "./dist/adapters/uk/index.cjs.js",
            "types": "./dist/adapters/uk/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "lint": "eslint . --ext .ts",
        "prepare": "npm run build"
    },
    "tsup": {
        "entry": [
            "src/index.ts",
            "src/plugins/installers.ts",
            "src/plugins/grid/index.ts",
            "src/plugins/financial/index.ts",
            "src/plugins/geographic/index.ts",
            "src/plugins/optimization/index.ts",
            "src/plugins/transport/index.ts",
            "src/adapters/uk/index.ts"
        ],
        "format": [
            "cjs",
            "esm"
        ],
        "dts": true,
        "splitting": true,
        "clean": true,
        "outDir": "dist"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "scenario",
        "modelling",
        "decarbonisation"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "tsup": "^6.0.0",
        "typescript": "^5.0.0",
        "vitest": "^1.0.0",
        "eslint": "^8.0.0",
        "prettier": "^2.0.0",
        "@types/node": "^20.0.0"
    }
}